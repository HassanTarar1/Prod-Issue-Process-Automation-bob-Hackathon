# IBM Bob Hackathon - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# GitHub Configuration
# Get your token from: https://github.com/settings/tokens
# Required scopes: repo (full control of private repositories)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO_OWNER=your_github_username
GITHUB_REPO_NAME=your_repository_name

# Slack Configuration
# Create an incoming webhook at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Application Configuration
SERVER_PORT=8080
LOG_FILE_PATH=production.log

# Playwright Configuration
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT=30000

# Optional: Database Configuration (if needed in future)
# DB_URL=jdbc:postgresql://localhost:5432/hackathon
# DB_USERNAME=postgres
# DB_PASSWORD=password

# Optional: Monitoring Configuration
# ENABLE_LOG_WATCHER=true
# LOG_WATCH_INTERVAL=5000

# Notes:
# - Never commit the actual .env file with real credentials
# - Keep this .env.example file updated with new configuration options
# - For demo purposes, the application works without GitHub token and Slack webhook
#   (it will use mock URLs and console logging as fallback)